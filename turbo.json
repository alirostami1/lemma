{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "concurrency": "20",
  "noUpdateNotifier": true,
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "lint": {},
    "lint:write": {},
    "format": {},
    "format:write": {},
    "check": {},
    "check:write": {},
    "check:types": {
      "dependsOn": ["^check:types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "generate:hono": {
      "dependsOn": ["@lemma/openapi-hono-generator#build"],
      "inputs": [
        "package.json",
        "orval.config.ts",
        "openapi/**",
        "$TURBO_ROOT$/packages/openapi-hono-generator/**"
      ],
      "outputs": ["src/generated/**"]
    },
    "generate:client": {
      "inputs": [
        "package.json",
        "orval.config.ts",
        "src/lib/custom-fetch.ts",
        "$TURBO_ROOT$/packages/api-contract/src/**",
        "$TURBO_ROOT$/packages/files/openapi/**",
        "$TURBO_ROOT$/packages/identity/openapi/**",
        "$TURBO_ROOT$/packages/ops/openapi/**",
        "$TURBO_ROOT$/packages/questions/openapi/**",
        "$TURBO_ROOT$/packages/workbook/openapi/**"
      ],
      "outputs": ["src/api/generated/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "passThroughEnv": ["LEMMA_*"]
    }
  }
}
