# Copy to /opt/lemma/.env on the VPS and replace every secret.
# Keep values shell-compatible: no spaces, no quotes, no unescaped `$`.
# Recommended: generate secrets with `openssl rand -base64 32 | tr -d '=+/'`.
# If POSTGRES_PASSWORD contains reserved URL characters, put its URL-encoded
# form in POSTGRES_PASSWORD_URL_ENCODED.

LEMMA_IMAGE_OWNER=alirostami1
# Runtime rollout state is written to /opt/lemma/.deploy-state.env by deploy.sh.
# Keep these in .env.example for manual fallback only; omit them from SOPS env.
LEMMA_IMAGE_TAG=replace-with-git-sha
LEMMA_SHARED_IMAGE_TAG=replace-with-git-sha
LEMMA_BLUE_IMAGE_TAG=replace-with-git-sha
LEMMA_GREEN_IMAGE_TAG=replace-with-git-sha
LEMMA_ACTIVE_COLOR=blue

LEMMA_WEB_DOMAIN=app.lemma.ac
LEMMA_API_DOMAIN=api.lemma.ac
LEMMA_ADMIN_DOMAIN=admin.lemma.ac
LEMMA_AUTH_DOMAIN=auth.lemma.ac
LEMMA_REALTIME_DOMAIN=realtime.lemma.ac
LEMMA_TLS_EMAIL=ops@lemma.ac
CLOUDFLARE_API_TOKEN=replace-me

LEMMA_WEB_APP_TITLE=Lemma
LEMMA_WEB_APP_URL=https://app.lemma.ac
LEMMA_WEB_API_URL=https://api.lemma.ac
LEMMA_WEB_REALTIME_URL=wss://realtime.lemma.ac/connection/websocket
LEMMA_WEB_OIDC_ISSUER_URI=https://auth.lemma.ac/realms/lemma
LEMMA_WEB_OIDC_CLIENT_ID=lemma-web

LEMMA_ADMIN_APP_TITLE=Lemma Admin
LEMMA_ADMIN_APP_URL=https://admin.lemma.ac
LEMMA_ADMIN_API_URL=https://api.lemma.ac
LEMMA_ADMIN_OIDC_ISSUER_URI=https://auth.lemma.ac/realms/lemma
LEMMA_ADMIN_OIDC_CLIENT_ID=lemma-admin

POSTGRES_USER=lemma
POSTGRES_PASSWORD=replace-me
POSTGRES_PASSWORD_URL_ENCODED=replace-me
POSTGRES_DB=lemma

KC_POSTGRES_USER=keycloak
KC_POSTGRES_PASSWORD=replace-me
KC_POSTGRES_DB=keycloak
KC_ADMIN=admin
KC_ADMIN_PW=replace-me
KC_HOSTNAME=https://auth.lemma.ac

GARAGE_DEFAULT_ACCESS_KEY=replace-me
GARAGE_DEFAULT_SECRET_KEY=replace-me
GARAGE_RPC_SECRET=replace-with-64-hex-chars
GARAGE_ADMIN_TOKEN=replace-me
GARAGE_METRICS_TOKEN=replace-me
LEMMA_S3_BUCKET=lemma-files
LEMMA_S3_REGION=garage

LEMMA_CENTRIFUGO_HTTP_API_KEY=replace-me
LEMMA_CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=replace-with-32-plus-random-chars
LEMMA_CENTRIFUGO_PUBLIC_URL=https://realtime.lemma.ac

LEMMA_API_WEB_ORIGINS=https://app.lemma.ac,https://admin.lemma.ac
LEMMA_OIDC_ISSUER_URL=https://auth.lemma.ac/realms/lemma
LEMMA_OIDC_JWKS_URL=http://keycloak:8080/realms/lemma/protocol/openid-connect/certs
LEMMA_OIDC_AUDIENCE=lemma-api

LEMMA_WORKBOOK_ENGINE=libreoffice
LEMMA_WORKBOOK_ENGINE_TIMEOUT_MS=30000
LEMMA_WORKBOOK_VALIDATION_TIMEOUT_MS=30000
LEMMA_WORKBOOK_MAX_FILE_BYTES=20971520
LEMMA_WORKBOOK_MAX_SHEETS=50
LEMMA_WORKBOOK_MAX_CELLS=500000
LEMMA_WORKBOOK_MAX_FORMULAS=50000
LEMMA_WORKBOOK_MAX_RESPONSE_BYTES=10485760

LEMMA_WORKER_ID=lemma-worker-vps
LEMMA_WORKER_OUTBOX_BATCH_SIZE=25
LEMMA_WORKER_OUTBOX_POLL_INTERVAL_MS=1000
LEMMA_WORKER_OUTBOX_LOCK_TIMEOUT_MS=60000
LEMMA_WORKER_OUTBOX_RETRY_DELAY_MS=5000
LEMMA_WORKER_OUTBOX_MAX_ATTEMPTS=10
LEMMA_WORKER_OUTBOX_CLEANUP_INTERVAL_MS=3600000
LEMMA_WORKER_OUTBOX_CLEANUP_BATCH_SIZE=500
LEMMA_WORKER_OUTBOX_PUBLISHED_RETENTION_MS=604800000
LEMMA_WORKER_QUESTION_GENERATION_CONCURRENCY=1
LEMMA_WORKER_WORKBOOK_VALIDATION_CONCURRENCY=1
LEMMA_WORKER_WORKBOOK_CALCULATION_CONCURRENCY=1
LEMMA_WORKER_QUEUE_RETRY_LIMIT=3
LEMMA_WORKER_QUEUE_RETRY_DELAY_SECONDS=30
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_INTERVAL_MS=10000
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_BATCH_SIZE=25
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_LOCK_TIMEOUT_MS=60000

LEMMA_OTEL_ENABLED=false
LEMMA_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
LEMMA_OTEL_METRIC_EXPORT_INTERVAL_MS=30000
