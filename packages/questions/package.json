{
  "name": "@lemma/questions",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./http": {
      "types": "./src/http/index.ts",
      "source": "./src/http/index.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    "./application": {
      "types": "./src/application/index.ts",
      "source": "./src/application/index.ts",
      "import": "./dist/application/index.js",
      "default": "./dist/application/index.js"
    },
    "./domain": {
      "types": "./src/domain/index.ts",
      "source": "./src/domain/index.ts",
      "import": "./dist/domain/index.js",
      "default": "./dist/domain/index.js"
    },
    "./inline-blueprint": {
      "types": "./src/domain/blueprint-document/index.ts",
      "source": "./src/domain/blueprint-document/index.ts",
      "import": "./dist/domain/blueprint-document/index.js",
      "default": "./dist/domain/blueprint-document/index.js"
    },
    "./infrastructure": {
      "types": "./src/infrastructure/index.ts",
      "source": "./src/infrastructure/index.ts",
      "import": "./dist/infrastructure/index.js",
      "default": "./dist/infrastructure/index.js"
    },
    "./module": {
      "types": "./src/module.ts",
      "source": "./src/module.ts",
      "import": "./dist/module.js",
      "default": "./dist/module.js"
    },
    "./openapi": {
      "types": "./openapi/openapi.ts",
      "source": "./openapi/openapi.ts",
      "import": "./openapi/openapi.ts",
      "default": "./openapi/openapi.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "generate:hono": "pnpm --filter @lemma/openapi-hono-generator build && orval",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "test": "node --conditions=source --import tsx --test \"src/**/*.test.ts\" \"openapi/**/*.test.ts\""
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@lemma/db": "workspace:*",
    "@lemma/domain": "workspace:*",
    "@lemma/error": "workspace:*",
    "@lemma/events": "workspace:*",
    "@lemma/files": "workspace:*",
    "@lemma/http": "workspace:*",
    "@lemma/identity": "workspace:*",
    "@lemma/observability": "workspace:*",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@lemma/openapi-hono-generator": "workspace:*",
    "@lemma/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "kysely": "catalog:",
    "orval": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
