{
  "name": "@lemma/http",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "development": "./src/browser.ts",
      "import": "./dist/browser.js",
      "default": "./dist/browser.js"
    },
    "./openapi": {
      "types": "./src/openapi.ts",
      "development": "./src/openapi.ts",
      "import": "./dist/openapi.js",
      "default": "./dist/openapi.js"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "check": "biome check",
    "format": "biome format",
    "lint": "biome lint"
  },
  "dependencies": {
    "@hono/zod-validator": "catalog:",
    "@lemma/error": "workspace:*",
    "hono": "catalog:",
    "openapi-types": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lemma/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@biomejs/biome": "catalog:"
  }
}
