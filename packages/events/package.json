{
  "name": "@lemma/events",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./domain": {
      "types": "./src/domain/index.ts",
      "source": "./src/domain/index.ts",
      "import": "./dist/domain/index.js",
      "default": "./dist/domain/index.js"
    },
    "./application": {
      "types": "./src/application/index.ts",
      "source": "./src/application/index.ts",
      "import": "./dist/application/index.js",
      "default": "./dist/application/index.js"
    },
    "./infrastructure": {
      "types": "./src/infrastructure/index.ts",
      "source": "./src/infrastructure/index.ts",
      "import": "./dist/infrastructure/index.js",
      "default": "./dist/infrastructure/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "test": "node --conditions=source --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@lemma/domain": "workspace:*",
    "@lemma/observability": "workspace:*",
    "kysely": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@lemma/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
