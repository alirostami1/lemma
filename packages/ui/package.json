{
  "name": "@lemma/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "imports": {
    "#/components/ui/*": {
      "types": "./src/components/ui/*.tsx",
      "development": "./src/components/ui/*.tsx",
      "import": "./dist/components/ui/*.js",
      "default": "./dist/components/ui/*.js"
    },
    "#/hooks/*": {
      "types": "./src/hooks/*.ts",
      "development": "./src/hooks/*.ts",
      "import": "./dist/hooks/*.js",
      "default": "./dist/hooks/*.js"
    },
    "#/lib/*": {
      "types": "./src/lib/*.ts",
      "development": "./src/lib/*.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "exports": {
    "./styles.css": {
      "development": "./src/styles.css",
      "default": "./src/styles.css"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "development": "./src/lib/utils.ts",
      "import": "./dist/lib/utils.js",
      "default": "./dist/lib/utils.js"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "development": "./src/hooks/*.ts",
      "import": "./dist/hooks/*.js",
      "default": "./dist/hooks/*.js"
    },
    "./components/*": {
      "types": "./src/components/ui/*.tsx",
      "development": "./src/components/ui/*.tsx",
      "import": "./dist/components/ui/*.js",
      "default": "./dist/components/ui/*.js"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4.11.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@lemma/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
