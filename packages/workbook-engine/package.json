{
  "name": "@lemma/workbook-engine",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./runtime": {
      "types": "./src/runtime.ts",
      "development": "./src/runtime.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./domain": {
      "types": "./src/domain.ts",
      "development": "./src/domain.ts",
      "import": "./dist/domain.js",
      "default": "./dist/domain.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "test": "vitest run src"
  },
  "dependencies": {
    "xlsx": "catalog:",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@lemma/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "yazl": "^3.3.1"
  }
}
