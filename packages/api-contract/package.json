{
  "name": "@lemma/api-contract",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/openapi.ts",
      "source": "./src/openapi.ts",
      "import": "./src/openapi.ts",
      "default": "./src/openapi.ts"
    },
    "./source": {
      "types": "./src/openapi.ts",
      "source": "./src/openapi.ts",
      "import": "./src/openapi.ts",
      "default": "./src/openapi.ts"
    }
  },
  "scripts": {
    "check": "biome check && pnpm lint",
    "check:write": "biome check --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "lint": "node --conditions=source --import tsx scripts/lint.ts"
  },
  "dependencies": {
    "@lemma/files": "workspace:*",
    "@lemma/http": "workspace:*",
    "@lemma/identity": "workspace:*",
    "@lemma/ops": "workspace:*",
    "@lemma/questions": "workspace:*",
    "@lemma/workbook": "workspace:*",
    "@redocly/cli": "^2.13.0",
    "@redocly/openapi-core": "^2.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "tsx": "catalog:"
  }
}
