{
  "components": {
    "schemas": {
      "CreateFileRequest": {
        "properties": { "name": { "type": "string" } },
        "required": ["name"],
        "type": "object"
      },
      "FileResponse": {
        "properties": { "file": { "type": "object" } },
        "required": ["file"],
        "type": "object"
      },
      "HealthResponse": {
        "properties": { "status": { "type": "string" } },
        "required": ["status"],
        "type": "object"
      }
    },
    "securitySchemes": {
      "keycloakAccessToken": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "Fixture",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/files": {
      "post": {
        "operationId": "createFile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateFileRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileResponse" }
              }
            },
            "description": "Created."
          }
        }
      }
    },
    "/files/{fileId}": {
      "delete": {
        "operationId": "deleteFile",
        "responses": {
          "204": { "description": "Deleted." }
        }
      },
      "get": {
        "operationId": "getFile",
        "parameters": [
          {
            "in": "query",
            "name": "cursor",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileResponse" }
              }
            },
            "description": "File."
          }
        }
      },
      "parameters": [
        {
          "in": "path",
          "name": "fileId",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "security": [{ "keycloakAccessToken": [] }]
    },
    "/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" }
              }
            },
            "description": "Healthy."
          }
        },
        "security": []
      }
    }
  },
  "security": [{ "keycloakAccessToken": [] }]
}
