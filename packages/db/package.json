{
  "name": "@lemma/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tables": {
      "types": "./src/types.d.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "migrate:latest": "tsx src/migrate.ts latest",
    "migrate:down": "tsx src/migrate.ts down",
    "migrate:up": "tsx src/migrate.ts up",
    "seed:dev": "tsx src/seed-dev.ts",
    "generate": "kysely-codegen --camel-case --dialect postgres --log-level info --out-file ./src/types.d.ts",
    "check": "biome check",
    "format": "biome format",
    "lint": "biome lint"
  },
  "dependencies": {
    "kysely": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@lemma/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "kysely-codegen": "^0.20.0",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "@biomejs/biome": "catalog:"
  }
}
