{
  "name": "@lemma/db",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tables": {
      "types": "./src/types.d.ts"
    },
    "./testing": {
      "types": "./src/testing/testcontainers-postgres.ts",
      "source": "./src/testing/testcontainers-postgres.ts",
      "import": "./dist/testing/testcontainers-postgres.js",
      "default": "./dist/testing/testcontainers-postgres.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "biome check",
    "check:types": "tsc --noEmit",
    "check:write": "biome check --write",
    "format": "biome format",
    "format:write": "biome format --write",
    "generate": "node --conditions=source --env-file=.env --import tsx src/generate-types.ts",
    "lint": "biome lint",
    "lint:write": "biome lint --write",
    "migrate:down": "node --conditions=source --env-file=.env --import tsx src/migrate.ts down",
    "migrate:latest": "node --conditions=source --env-file=.env --import tsx src/migrate.ts latest",
    "migrate:up": "node --conditions=source --env-file=.env --import tsx src/migrate.ts up",
    "seed:dev": "node --conditions=source --env-file=.env --import tsx src/seed-dev.ts",
    "test": "node --conditions=source --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@lemma/config": "workspace:*",
    "kysely": "catalog:",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@lemma/typescript-config": "workspace:*",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "kysely-codegen": "^0.20.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
