{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/src/**/*",
      "**/scripts/**/*",
      "infra/*.json",
      "**/biome.json",
      "**/package.json",
      "**/tsconfig.json",
      "**/orval.config.*",
      "**/openapi.ts",
      "**/*.config.{ts,js,cjs}",
      "turbo.json"
    ]
  },
  "overrides": [
    {
      "includes": [
        "**/src/gen/**/*",
        "**/src/api/generated/**/*",
        "**/src/kc.gen.tsx"
      ],
      "linter": {
        "enabled": false
      }
    }
  ],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "useEditorconfig": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  }
}
