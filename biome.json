{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "root": true,
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/src/**/*",
      "**/scripts/**/*",
      "infra/*.json",
      "**/biome.json",
      "**/package.json",
      "**/tsconfig.json",
      "**/orval.config.*",
      "**/openapi.ts",
      "**/*.config.{ts,js,cjs}",
      "turbo.json"
    ]
  },
  "overrides": [
    {
      "includes": ["**/src/api/generated/**/*", "**/src/kc.gen.tsx"],
      "linter": {
        "enabled": false
      }
    }
  ],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "useEditorconfig": true
  },
  "assist": {
    "actions": {
      "recommended": true,
      "source": {
        "noDuplicateClasses": "on",
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedEnumMembers": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedPackageJson": "on",
        "useSortedProperties": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  }
}
