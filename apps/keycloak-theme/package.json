{
  "name": "keycloak-theme",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "format": "biome format",
    "lint": "biome lint",
