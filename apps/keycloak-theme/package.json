  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.1",
    "storybook": "^10.3.5",
    "typescript": "catalog:",
    "vite": "^8.0.0"
  }
