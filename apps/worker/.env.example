NODE_ENV=development
LEMMA_WORKER_DATABASE_URL=postgres://lemma:lemma@localhost:5432/lemma?sslmode=disable
LEMMA_WORKER_ID=lemma-worker-local

LEMMA_S3_REGION=garage
LEMMA_S3_BUCKET=lemma-files
LEMMA_S3_ACCESS_KEY_ID=garagelemma
LEMMA_S3_SECRET_ACCESS_KEY=lemma-garage-secret-key
LEMMA_S3_ENDPOINT=http://localhost:3900
LEMMA_S3_FORCE_PATH_STYLE=true
LEMMA_S3_UPLOAD_URL_EXPIRES_IN_SECONDS=900
LEMMA_S3_DOWNLOAD_URL_EXPIRES_IN_SECONDS=900

LEMMA_WORKBOOK_ENGINE=libreoffice
LEMMA_WORKBOOK_LIBREOFFICE_SERVICE_URL=http://localhost:8080
LEMMA_WORKBOOK_ENGINE_TIMEOUT_MS=30000
LEMMA_WORKBOOK_VALIDATION_TIMEOUT_MS=30000
LEMMA_WORKBOOK_MAX_FILE_BYTES=20971520
LEMMA_WORKBOOK_MAX_SHEETS=50
LEMMA_WORKBOOK_MAX_CELLS=500000
LEMMA_WORKBOOK_MAX_FORMULAS=50000
LEMMA_WORKBOOK_MAX_RESPONSE_BYTES=10485760

LEMMA_CENTRIFUGO_PUBLIC_URL=http://localhost:8000
LEMMA_CENTRIFUGO_HTTP_API_URL=http://localhost:8000/api
LEMMA_CENTRIFUGO_HTTP_API_KEY=lemma-centrifugo-api-key
LEMMA_CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=lemma-centrifugo-token-secret-key-32chars
LEMMA_CENTRIFUGO_TOKEN_TTL_SECONDS=3600

LEMMA_OTEL_ENABLED=true
LEMMA_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LEMMA_OTEL_METRIC_EXPORT_INTERVAL_MS=30000

LEMMA_WORKER_OUTBOX_BATCH_SIZE=25
LEMMA_WORKER_OUTBOX_POLL_INTERVAL_MS=1000
LEMMA_WORKER_OUTBOX_LOCK_TIMEOUT_MS=60000
LEMMA_WORKER_OUTBOX_RETRY_DELAY_MS=5000
LEMMA_WORKER_OUTBOX_MAX_ATTEMPTS=10
LEMMA_WORKER_OUTBOX_CLEANUP_INTERVAL_MS=3600000
LEMMA_WORKER_OUTBOX_CLEANUP_BATCH_SIZE=500
LEMMA_WORKER_OUTBOX_PUBLISHED_RETENTION_MS=604800000
LEMMA_WORKER_QUESTION_GENERATION_CONCURRENCY=1
LEMMA_WORKER_WORKBOOK_VALIDATION_CONCURRENCY=1
LEMMA_WORKER_WORKBOOK_CALCULATION_CONCURRENCY=1
LEMMA_WORKER_QUEUE_RETRY_LIMIT=3
LEMMA_WORKER_QUEUE_RETRY_DELAY_SECONDS=30
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_INTERVAL_MS=10000
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_BATCH_SIZE=25
LEMMA_WORKER_FAILED_QUEUE_RECONCILE_LOCK_TIMEOUT_MS=60000
